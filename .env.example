# ---------------------------------------------------------------
# Mock flags — set ALL_MOCK=true to run the entire pipeline
# without any real API credentials (great for local development)
# ---------------------------------------------------------------
ALL_MOCK=true

# Set individual mocks (overridden by ALL_MOCK=true)
SHOPIFY_MOCK=false
GMAIL_MOCK=false
SHEETS_MOCK=false
SLACK_MOCK=false

# ---------------------------------------------------------------
# Shopify — webhook secret for HMAC signature verification
# Docs: https://shopify.dev/docs/apps/webhooks/configuration/https#step-5-verify-the-webhook
# ---------------------------------------------------------------
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret_here

# ---------------------------------------------------------------
# Gmail — OAuth2 credentials for sending confirmation emails
# Docs: https://developers.google.com/gmail/api/quickstart/python
# ---------------------------------------------------------------
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
GMAIL_SENDER=your_gmail_address@gmail.com

# ---------------------------------------------------------------
# Google Sheets — service account credentials and target sheet
# Docs: https://developers.google.com/sheets/api/guides/authorizing
# ---------------------------------------------------------------
SHEETS_CREDENTIALS_PATH=service_account.json
SPREADSHEET_ID=your_google_spreadsheet_id_here
SHEET_NAME=Orders

# ---------------------------------------------------------------
# Slack — Incoming Webhook URL for team notifications
# Docs: https://api.slack.com/messaging/webhooks
# ---------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ---------------------------------------------------------------
# Server
# ---------------------------------------------------------------
PORT=8000
